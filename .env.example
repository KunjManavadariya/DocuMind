# Local-only DocuMind with managed services.
# Copy to `.env` and fill real values on your machine only.
# Never commit `.env`.

# Runtime
APP_ENV=local-managed
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=http://localhost:8000

# Build mode
# Keep false for smooth local demos. true installs heavy RAGAS + sentence-transformers.
INSTALL_ML_DEPS=false

# Neon Postgres / pgvector
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Upstash Redis
# One Upstash Redis URL is enough for local demo. Use separate DBs later if needed.
REDIS_URL=rediss://default:TOKEN@HOST:PORT/0
CELERY_BROKER_URL=rediss://default:TOKEN@HOST:PORT/0?ssl_cert_reqs=CERT_REQUIRED
CELERY_RESULT_BACKEND=rediss://default:TOKEN@HOST:PORT/0?ssl_cert_reqs=CERT_REQUIRED
CACHE_ENABLED=true
EMBEDDING_CACHE_TTL_SECONDS=86400
ANSWER_CACHE_TTL_SECONDS=600

# Cloudflare R2 source document storage
DOCUMENT_STORAGE_PROVIDER=r2
CLOUDFLARE_R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=replace_me
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace_me
CLOUDFLARE_R2_BUCKET=documind
LOCAL_DOCUMENT_STORAGE_DIR=storage/source-documents

# URL ingestion limits
URL_FETCH_TIMEOUT_SECONDS=10
URL_FETCH_MAX_BYTES=2000000

# Gemini providers
LLM_PROVIDER=gemini
GENERATION_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
EVALUATION_PROVIDER=local
GEMINI_API_KEY=replace_me
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TEMPERATURE=0.2
EMBEDDING_DIMENSION=384

# Reranking
RERANKER_PROVIDER=local
RERANKER_CANDIDATE_MULTIPLIER=4
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Optional RAGAS evaluator
RAGAS_LLM_MODEL=gemini-2.0-flash
RAGAS_EMBEDDING_MODEL=gemini-embedding-001

# Optional OpenAI fallback
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

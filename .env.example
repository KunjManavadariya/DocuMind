# Local development defaults. Copy to .env when you start wiring real services.

# Backend
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local Docker Compose services
INSTALL_ML_DEPS=false
DATABASE_URL=postgresql://documind:documind@postgres:5432/documind
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CACHE_ENABLED=true
EMBEDDING_CACHE_TTL_SECONDS=86400
ANSWER_CACHE_TTL_SECONDS=600

# Future managed services
NEON_DATABASE_URL=
UPSTASH_REDIS_URL=
DOCUMENT_STORAGE_PROVIDER=local
LOCAL_DOCUMENT_STORAGE_DIR=storage/source-documents
URL_FETCH_TIMEOUT_SECONDS=10
URL_FETCH_MAX_BYTES=2000000
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# Model providers
LLM_PROVIDER=gemini
GENERATION_PROVIDER=local
EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSION=384
RERANKER_PROVIDER=local
RERANKER_CANDIDATE_MULTIPLIER=4
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
EVALUATION_PROVIDER=local
RAGAS_LLM_MODEL=gemini-2.0-flash
RAGAS_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TEMPERATURE=0.2
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Frontend
VITE_API_BASE_URL=http://localhost:8000
